<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>НиколкаТуб Pro | Социальная платформа с ИИ</title>
    
    <meta name="description" content="Социальная платформа с ИИ-ассистентом, усиленной защитой и современным дизайном">
    <meta name="theme-color" content="#0a0a0a">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            color: #f5f5f5;
            min-height: 100vh;
            transition: all 0.3s ease;
        }

        /* Анимации */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes glowPulse {
            0%, 100% { box-shadow: 0 0 5px rgba(240, 148, 51, 0.3); }
            50% { box-shadow: 0 0 20px rgba(240, 148, 51, 0.6); }
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .animate-in {
            animation: fadeInUp 0.5s ease forwards;
        }

        /* Шапка с анимацией */
        .header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 12px 20px;
            transition: all 0.3s;
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 26px;
            font-weight: 800;
            background: linear-gradient(135deg, #f09433, #d62976, #962fbf, #4facfe);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            cursor: pointer;
            animation: glowPulse 2s infinite;
        }

        /* 2FA Код */
        .twofa-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 2000;
            justify-content: center;
            align-items: center;
        }

        /* Личный кабинет */
        .profile-modal {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-radius: 24px;
            padding: 30px;
            width: 90%;
            max-width: 500px;
            z-index: 1000;
            border: 1px solid rgba(240,148,51,0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        .profile-modal.active, .twofa-modal.active {
            display: flex;
        }

        /* Настройки интерфейса */
        .settings-panel {
            margin-top: 20px;
            padding: 15px;
            background: rgba(255,255,255,0.05);
            border-radius: 16px;
        }

        .setting-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .theme-switch, .anim-switch {
            width: 50px;
            height: 26px;
            background: #262626;
            border-radius: 13px;
            cursor: pointer;
            position: relative;
            transition: 0.3s;
        }

        .theme-switch.active, .anim-switch.active {
            background: #f09433;
        }

        .theme-switch::after, .anim-switch::after {
            content: '';
            position: absolute;
            width: 22px;
            height: 22px;
            background: white;
            border-radius: 50%;
            top: 2px;
            left: 3px;
            transition: 0.3s;
        }

        .theme-switch.active::after, .anim-switch.active::after {
            transform: translateX(24px);
        }

        /* Нейросеть - ИИ ассистент */
        .ai-assistant {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #f09433, #d62976);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 200;
            animation: glowPulse 2s infinite;
            box-shadow: 0 5px 20px rgba(240,148,51,0.4);
            transition: transform 0.3s;
        }

        .ai-assistant:hover {
            transform: scale(1.1);
        }

        .ai-chat {
            display: none;
            position: fixed;
            bottom: 100px;
            right: 20px;
            width: 350px;
            height: 500px;
            background: #1a1a2e;
            border-radius: 20px;
            flex-direction: column;
            overflow: hidden;
            z-index: 200;
            border: 1px solid rgba(240,148,51,0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .ai-chat.active {
            display: flex;
        }

        /* Остальные стили как в предыдущей версии */
        .container {
            max-width: 1400px;
            margin: 20px auto;
            padding: 0 20px;
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
        }

        .sidebar {
            width: 260px;
            position: sticky;
            top: 80px;
            height: fit-content;
        }

        .sidebar-item {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 14px 20px;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: #f5f5f5;
            margin-bottom: 8px;
        }

        .sidebar-item:hover, .sidebar-item.active {
            background: linear-gradient(90deg, rgba(240,148,51,0.2), transparent);
            transform: translateX(8px);
            color: #f09433;
        }

        .main-feed {
            flex: 2;
            min-width: 300px;
        }

        .stories {
            background: rgba(30,30,46,0.5);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 16px;
            margin-bottom: 24px;
            overflow-x: auto;
            white-space: nowrap;
            display: flex;
            gap: 16px;
        }

        .story {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: transform 0.3s;
        }

        .story:hover {
            transform: scale(1.05);
        }

        .story-avatar {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f09433, #d62976, #962fbf);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            transition: all 0.3s;
        }

        .post {
            background: rgba(30,30,46,0.5);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            margin-bottom: 20px;
            overflow: hidden;
            transition: all 0.3s ease;
            animation: fadeInUp 0.5s ease;
        }

        .post:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .messenger-section {
            width: 340px;
            position: sticky;
            top: 80px;
            height: calc(100vh - 100px);
            background: rgba(30,30,46,0.5);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Адаптив */
        @media (max-width: 900px) {
            .sidebar {
                display: none;
            }
            .messenger-section {
                width: 100%;
                height: 500px;
            }
            .ai-chat {
                width: 90%;
                right: 5%;
            }
        }
    </style>
</head>
<body>

<div class="header">
    <div class="header-container">
        <div class="logo" onclick="location.reload()">✨ НиколкаТуб Pro</div>
        <div class="user-info" id="userInfo" onclick="openProfileSettings()" style="display:flex; align-items:center; gap:12px; background:rgba(255,255,255,0.1); padding:6px 16px; border-radius:24px; cursor:pointer;">
            <div id="headerAvatar" style="width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#f09433,#d62976); display:flex; align-items:center; justify-content:center;">👤</div>
            <span id="headerUsername">Войти</span>
        </div>
    </div>
</div>

<!-- 2FA Модальное окно -->
<div class="twofa-modal" id="twofaModal">
    <div style="background:#1a1a2e; padding:30px; border-radius:20px; text-align:center; max-width:400px;">
        <h2>🔐 Двухфакторная аутентификация</h2>
        <p style="margin:20px 0;">Введите код из приложения-аутентификатора</p>
        <input type="text" id="twofaCode" placeholder="000000" style="width:100%; padding:12px; background:#262626; border:none; border-radius:12px; color:white; text-align:center; font-size:24px; letter-spacing:8px;">
        <button onclick="verify2FA()" style="margin-top:20px; width:100%; padding:12px; background:linear-gradient(135deg,#f09433,#d62976); border:none; border-radius:12px; color:white; cursor:pointer;">Подтвердить</button>
    </div>
</div>

<!-- Личный кабинет -->
<div class="profile-modal" id="profileModal">
    <div style="text-align:center;">
        <div style="font-size:60px; margin-bottom:10px;" id="profileAvatar">👤</div>
        <h2 id="profileName">Гость</h2>
        
        <div class="settings-panel">
            <h3>⚙️ Настройки интерфейса</h3>
            <div class="setting-item">
                <span>🌙 Тёмная тема</span>
                <div class="theme-switch" id="themeSwitch" onclick="toggleTheme()"></div>
            </div>
            <div class="setting-item">
                <span>✨ Анимации</span>
                <div class="anim-switch active" id="animSwitch" onclick="toggleAnimations()"></div>
            </div>
            <div class="setting-item">
                <span>🔔 Уведомления</span>
                <div class="theme-switch active" id="notifSwitch" onclick="toggleNotifications()"></div>
            </div>
        </div>
        
        <div class="settings-panel">
            <h3>🛡️ Безопасность</h3>
            <div class="setting-item">
                <span>🔐 2FA Защита</span>
                <div class="theme-switch" id="twofaSwitch" onclick="toggle2FA()"></div>
            </div>
            <div class="setting-item">
                <span>📱 Привязать телефон</span>
                <button onclick="bindPhone()" style="background:#f09433; border:none; padding:5px 15px; border-radius:20px;">+ Добавить</button>
            </div>
        </div>
        
        <button onclick="logout()" style="margin-top:20px; width:100%; padding:12px; background:rgba(255,255,255,0.1); border:none; border-radius:12px; color:#ff6b6b; cursor:pointer;">🚪 Выйти</button>
        <button onclick="closeProfile()" style="margin-top:10px; width:100%; padding:12px; background:transparent; border:1px solid rgba(255,255,255,0.2); border-radius:12px; cursor:pointer;">Закрыть</button>
    </div>
</div>

<!-- ИИ Ассистент -->
<div class="ai-assistant" onclick="toggleAIChat()">
    🤖
</div>
<div class="ai-chat" id="aiChat">
    <div style="padding:16px; background:linear-gradient(135deg,#f09433,#d62976); display:flex; justify-content:space-between;">
        <span>🤖 ИИ-Ассистент Николка</span>
        <button onclick="toggleAIChat()" style="background:none; border:none; color:white; cursor:pointer;">✖</button>
    </div>
    <div id="aiMessages" style="flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:12px;">
        <div style="background:#262626; padding:10px; border-radius:12px; max-width:80%;">Привет! Я нейросеть Николка. Чем могу помочь? 🧠</div>
    </div>
    <div style="display:flex; gap:10px; padding:12px; border-top:1px solid rgba(255,255,255,0.1);">
        <input type="text" id="aiInput" placeholder="Спроси меня о чём угодно..." style="flex:1; padding:10px; background:#262626; border:none; border-radius:20px; color:white;">
        <button onclick="sendToAI()" style="background:#f09433; border:none; padding:0 16px; border-radius:20px; cursor:pointer;">➤</button>
    </div>
</div>

<div class="container">
    <div class="sidebar">
        <div class="sidebar-item active" onclick="switchSection('feed')">🏠 Лента</div>
        <div class="sidebar-item" onclick="switchSection('music')">🎵 Музыка</div>
        <div class="sidebar-item" onclick="switchSection('video')">🎬 Видео</div>
        <div class="sidebar-item" onclick="openUpload()">📸 Загрузить</div>
        <div class="sidebar-item" onclick="openProfileSettings()">👤 Мой профиль</div>
    </div>

    <div class="main-feed" id="feedSection">
        <div class="stories" id="storiesContainer"></div>
        <div id="postsContainer"></div>
    </div>

    <div class="main-feed" id="musicSection" style="display: none;">
        <div style="background:rgba(30,30,46,0.5); backdrop-filter:blur(10px); border-radius:20px; padding:20px;">
            <h2>🎵 Музыкальный плеер</h2>
            <div id="musicGrid"></div>
        </div>
    </div>

    <div class="main-feed" id="videoSection" style="display: none;">
        <div style="background:rgba(30,30,46,0.5); backdrop-filter:blur(10px); border-radius:20px; padding:20px;">
            <h2>🎬 Видео</h2>
            <div id="videoGrid"></div>
        </div>
    </div>

    <div class="messenger-section">
        <div style="padding:16px; border-bottom:1px solid rgba(255,255,255,0.1); font-weight:700;">💬 Мессенджер</div>
        <div class="chat-list" id="chatList" style="flex:1; overflow-y:auto;"></div>
    </div>
</div>

<script>
    // ========== ЗАЩИТА И НАСТРОЙКИ ==========
    let currentUser = null;
    let twoFAEnabled = false;
    let twoFACode = "123456";
    let settings = {
        darkTheme: true,
        animations: true,
        notifications: true
    };
    
    // Загрузка настроек
    function loadSettings() {
        const saved = localStorage.getItem('userSettings');
        if (saved) settings = JSON.parse(saved);
        applySettings();
    }
    
    function applySettings() {
        if (!settings.darkTheme) {
            document.body.style.background = "#f0f0f0";
            document.body.style.color = "#121212";
        } else {
            document.body.style.background = "linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%)";
            document.body.style.color = "#f5f5f5";
        }
        document.getElementById('themeSwitch').classList.toggle('active', settings.darkTheme);
        document.getElementById('animSwitch').classList.toggle('active', settings.animations);
        document.getElementById('notifSwitch').classList.toggle('active', settings.notifications);
    }
    
    function toggleTheme() {
        settings.darkTheme = !settings.darkTheme;
        localStorage.setItem('userSettings', JSON.stringify(settings));
        applySettings();
        showNotification(settings.darkTheme ? "🌙 Тёмная тема включена" : "☀️ Светлая тема включена");
    }
    
    function toggleAnimations() {
        settings.animations = !settings.animations;
        localStorage.setItem('userSettings', JSON.stringify(settings));
        const style = document.createElement('style');
        if (!settings.animations) {
            style.textContent = '*, .post, .sidebar-item, .story { animation: none !important; transition: none !important; transform: none !important; }';
        } else {
            style.textContent = '';
        }
        document.head.appendChild(style);
        showNotification(settings.animations ? "✨ Анимации включены" : "⏸️ Анимации выключены");
    }
    
    function toggleNotifications() {
        settings.notifications = !settings.notifications;
        localStorage.setItem('userSettings', JSON.stringify(settings));
        showNotification(settings.notifications ? "🔔 Уведомления включены" : "🔕 Уведомления выключены");
    }
    
    function toggle2FA() {
        twoFAEnabled = !twoFAEnabled;
        localStorage.setItem('twoFAEnabled', twoFAEnabled);
        showNotification(twoFAEnabled ? "🔐 2FA защита включена" : "🔓 2FA защита выключена");
    }
    
    function bindPhone() {
        const phone = prompt("Введите номер телефона:");
        if (phone && phone.length > 5) {
            localStorage.setItem('userPhone', phone);
            showNotification("📱 Телефон привязан: " + phone.substring(0, 4) + "****");
        }
    }
    
    // 2FA проверка
    function require2FA() {
        if (twoFAEnabled && currentUser) {
            document.getElementById('twofaModal').classList.add('active');
            return false;
        }
        return true;
    }
    
    function verify2FA() {
        const code = document.getElementById('twofaCode').value;
        if (code === twoFACode) {
            document.getElementById('twofaModal').classList.remove('active');
            showNotification("✅ 2FA пройдена успешно!");
            document.getElementById('twofaCode').value = '';
        } else {
            showNotification("❌ Неверный код 2FA!");
        }
    }
    
    // Регистрация с защитой
    function register() {
        const name = document.getElementById('regName')?.value;
        const avatar = document.getElementById('regAvatar')?.value || "👤";
        if (name && name.length >= 3) {
            const password = prompt("Придумайте пароль (минимум 6 символов):");
            if (password && password.length >= 6) {
                currentUser = { name: name, avatar: avatar, password: btoa(password), createdAt: new Date().toISOString() };
                localStorage.setItem('currentUser', JSON.stringify(currentUser));
                localStorage.setItem('userPassword', btoa(password));
                document.getElementById('authModal')?.classList.remove('active');
                updateUI();
                showNotification(`🎉 Добро пожаловать, ${name}! Ваш аккаунт защищён.`);
                if (twoFAEnabled) require2FA();
            } else {
                showNotification("Пароль должен быть не менее 6 символов!");
            }
        } else {
            showNotification("Имя должно быть не менее 3 символов!");
        }
    }
    
    // Вход с защитой
    function login() {
        const name = prompt("Введите имя пользователя:");
        const password = prompt("Введите пароль:");
        if (name && password) {
            const saved = localStorage.getItem('currentUser');
            if (saved) {
                const user = JSON.parse(saved);
                if (user.name === name && atob(user.password) === password) {
                    currentUser = user;
                    localStorage.setItem('currentUser', JSON.stringify(currentUser));
                    updateUI();
                    showNotification(`👋 С возвращением, ${name}!`);
                    if (twoFAEnabled) require2FA();
                } else {
                    showNotification("❌ Неверное имя или пароль!");
                }
            } else {
                showNotification("Аккаунт не найден. Зарегистрируйтесь!");
            }
        }
    }
    
    // Остальной функционал
    let posts = [];
    let stories = [];
    
    function loadData() {
        const savedUser = localStorage.getItem('currentUser');
        if (savedUser) currentUser = JSON.parse(savedUser);
        
        const savedPosts = localStorage.getItem('posts');
        if (savedPosts) posts = JSON.parse(savedPosts);
        else {
            posts = [
                { id: 0, username: "nikolka", avatar: "😂", content: "🐱", contentType: "emoji", caption: "Смешной кот #прикол", likes: { "❤️": 1245, "😂": 89, "😮": 12 }, time: "2 часа назад" }
            ];
        }
        
        const savedStories = localStorage.getItem('stories');
        if (savedStories) stories = JSON.parse(savedStories);
        else {
            stories = [
                { id: 0, username: "nikolka", avatar: "😂", content: "🐱 Привет!", type: "text" }
            ];
        }
        
        updateUI();
    }
    
    function updateUI() {
        if (currentUser) {
            document.getElementById('headerUsername').innerText = currentUser.name;
            document.getElementById('headerAvatar').innerHTML = currentUser.avatar;
            document.getElementById('profileName').innerText = currentUser.name;
            document.getElementById('profileAvatar').innerHTML = currentUser.avatar;
        } else {
            document.getElementById('headerUsername').innerHTML = '<button onclick="login()" style="background:none; border:none; color:#f09433; cursor:pointer;">Войти</button> / <button onclick="openRegister()" style="background:none; border:none; color:#f09433; cursor:pointer;">Регистр</button>';
        }
        renderPosts();
        renderStories();
    }
    
    function openRegister() {
        const modal = document.createElement('div');
        modal.className = 'modal';
        modal.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:1000; display:flex; justify-content:center; align-items:center;';
        modal.innerHTML = `
            <div style="background:#1a1a2e; padding:30px; border-radius:20px; width:90%; max-width:400px;">
                <h2>📝 Регистрация</h2>
                <input type="text" id="regName" placeholder="Имя пользователя" style="width:100%; padding:12px; margin:10px 0; background:#262626; border:none; border-radius:12px; color:white;">
                <input type="text" id="regAvatar" placeholder="Эмодзи аватара (например, 😂)" style="width:100%; padding:12px; margin:10px 0; background:#262626; border:none; border-radius:12px; color:white;">
                <button onclick="register()" style="width:100%; padding:12px; background:linear-gradient(135deg,#f09433,#d62976); border:none; border-radius:12px; color:white; cursor:pointer;">Зарегистрироваться</button>
                <button onclick="this.parentElement.parentElement.remove()" style="width:100%; margin-top:10px; padding:12px; background:#262626; border:none; border-radius:12px; cursor:pointer;">Закрыть</button>
            </div>
        `;
        document.body.appendChild(modal);
    }
    
    // Нейросеть (искусственный интеллект)
    function sendToAI() {
        const input = document.getElementById('aiInput');
        const message = input.value.trim();
        if (!message) return;
        
        const aiMessages = document.getElementById('aiMessages');
        const userMsg = document.createElement('div');
        userMsg.style.cssText = 'background:#f09433; padding:10px; border-radius:12px; max-width:80%; align-self:flex-end; margin-left:auto;';
        userMsg.innerText = message;
        aiMessages.appendChild(userMsg);
        input.value = '';
        
        // Имитация нейросети
        setTimeout(() => {
            let reply = "🧠 Я нейросеть Николка. ";
            if (message.toLowerCase().includes("привет")) reply += "Привет-привет! Как дела? 😊";
            else if (message.toLowerCase().includes("помощь")) reply += "Чем могу помочь? Могу рассказать о функциях сайта!";
            else if (message.toLowerCase().includes("спасибо")) reply += "Пожалуйста! Рад помочь! 🎉";
            else reply += "Интересный вопрос! Я ещё учусь, но скоро смогу ответить на всё! 🤖";
            
            const aiMsg = document.createElement('div');
            aiMsg.style.cssText = 'background:#262626; padding:10px; border-radius:12px; max-width:80%;';
            aiMsg.innerText = reply;
            aiMessages.appendChild(aiMsg);
            aiMessages.scrollTop = aiMessages.scrollHeight;
            
            if (settings.notifications) {
                showNotification("🤖 ИИ-ассистент ответил!");
            }
        }, 500);
    }
    
    function toggleAIChat() {
        document.getElementById('aiChat').classList.toggle('active');
    }
    
    function showNotification(msg) {
        if (!settings.notifications) return;
        const toast = document.createElement('div');
        toast.style.cssText = 'position:fixed; bottom:100px; right:20px; background:#1a1a2e; border-left:4px solid #f09433; padding:12px 20px; border-radius:12px; z-index:1000; animation: fadeInUp 0.3s ease; max-width:300px;';
        toast.innerText = msg;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
    
    function renderPosts() {
        const container = document.getElementById('postsContainer');
        if (!container) return;
        container.innerHTML = '';
        posts.forEach(post => {
            const div = document.createElement('div');
            div.className = 'post';
            div.innerHTML = `
                <div class="post-header" style="padding:16px;">
                    <div style="display:flex; align-items:center; gap:12px;">
                        <div style="width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,#f09433,#d62976); display:flex; align-items:center; justify-content:center;">${post.avatar}</div>
                        <div><strong>${post.username}</strong><br><span style="font-size:11px; color:#8e8e8e;">${post.time}</span></div>
                    </div>
                </div>
                <div class="post-content" style="min-height:200px; display:flex; align-items:center; justify-content:center; font-size:60px;">${post.content}</div>
                <div class="post-caption" style="padding:16px;"><strong>${post.username}</strong> ${post.caption}</div>
            `;
            container.appendChild(div);
        });
    }
    
    function renderStories() {
        const container = document.getElementById('storiesContainer');
        if (!container) return;
        container.innerHTML = '';
        stories.forEach(story => {
            const div = document.createElement('div');
            div.className = 'story';
            div.innerHTML = `<div class="story-avatar">${story.avatar}</div><div style="font-size:12px;">${story.username}</div>`;
            container.appendChild(div);
        });
    }
    
    function switchSection(section) {
        document.getElementById('feedSection').style.display = section === 'feed' ? 'block' : 'none';
        document.getElementById('musicSection').style.display = section === 'music' ? 'block' : 'none';
        document.getElementById('videoSection').style.display = section === 'video' ? 'block' : 'none';
    }
    
    function openProfileSettings() {
        if (!currentUser) {
            login();
            return;
        }
        document.getElementById('profileModal').classList.add('active');
    }
    
    function closeProfile() {
        document.getElementById('profileModal').classList.remove('active');
    }
    
    function logout() {
        currentUser = null;
        localStorage.removeItem('currentUser');
        updateUI();
        closeProfile();
        showNotification("👋 Вы вышли из аккаунта");
    }
    
    function openUpload() {
        showNotification("📸 Функция загрузки будет доступна в следующем обновлении!");
    }
    
    // Инициализация
    loadSettings();
    loadData();
    
    console.log('✅ НиколкаТуб Pro с нейросетью, 2FA и настройками запущен!');
</script>
</body>
</html>
